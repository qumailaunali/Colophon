# Supabase project settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key: Supabase project settings -> API -> service_role secret.
# Server-only. Used solely by app/api/account/delete to remove the auth user
# on account deletion. Never expose this to the client / NEXT_PUBLIC_*.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Direct Postgres connection (Project Settings -> Database -> Connection
# string). Server-only, full DDL access — used solely by
# scripts/run-migrations.mjs (npm run db:migrate). Optional: only needed if
# you want migrations applied automatically instead of pasting them into the
# Supabase SQL editor by hand.
DATABASE_URL=postgresql://postgres:your-db-password@db.your-project-ref.supabase.co:5432/postgres

# Azure Speech (optional premium TTS provider). From the Azure Portal:
# Speech resource -> Keys and Endpoint. Server-only — used exclusively by
# app/api/tts/azure/* to call Azure on the user's behalf, never exposed to
# the client. Leave unset to use only the free browser voice (default).
AZURE_SPEECH_KEY=your-azure-speech-key
AZURE_SPEECH_REGION=your-azure-region
